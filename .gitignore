# Generated preset caches (LLM-generated, not curated)
shared/templates/**/*_generated.json

# Frontend (React) — node_modules + ad-hoc dist locations.
# The actual build output lives under static/game_admin/ and IS committed
# so the existing deploy flow keeps working without a Node install.
frontend/node_modules/
frontend/dist/

# Environment Variables & API Keys
.env
.env.local
.env.*.local
*.key
*.pem
# Per-world secrets overlay (api keys, passwords) — never commit
worlds/*/secrets.json
secrets.json

# Internal planning notes — not for public release
development_instructions/
Aufgaben
documentation/

# Legacy ./storage runtime data (pre-worlds/)
storage/

# Legacy JSON-Backups, nach DB-Migration aus den Welten verschoben
migrated_backups/

# Migrations-/Cleanup-Backups (z.B. faceswap_cleanup) — Wiederherstellungspunkte, nicht committen
migration_backup/

# Internal helper / migration scripts — not part of the public release
scripts/
tools/

# Files removed from public release
docs/llm-task-mapping.md
CHAT_PROMPTS.md
MODEL_TESTS.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
