.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store

# Shared cross-world files
shared/templates/**/*nsfw*

# Worlds (each world is a separate storage directory)
worlds/*
!worlds/demo/

# World-specific start scripts (only start-demo.sh is tracked)
start-*.sh
!start-demo.sh

# Logs
logs/

# Individual User/Agent Storage
telegram_chats.json
Aufgaben.md

# Model Files (Large Binary Files) — ignore the model binaries themselves,
# but keep models/ tracked so per-model LICENSE/NOTICE stay in the repo.
# Fetch the binaries with ./fetch_models.sh
/models/**/*.onnx
/models/**/*.pth
/models/**/*.safetensors
/models/**/*.gguf
voices/*.wav

# original comfyui workflows
workflows/ComfyUI-Workflows/

