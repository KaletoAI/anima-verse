        {
          "key": "language",
          "label": "Language",
          "label_de": "Sprache",
          "type": "select",
          "required": true,
          "llm_generable": true,
          "options": [
            {
              "value": "de",
              "label": "Deutsch"
            },
            {
              "value": "en",
              "label": "English"
            },
            {
              "value": "fr",
              "label": "Français"
            },
            {
              "value": "es",
              "label": "Español"
            },
            {
              "value": "it",
              "label": "Italiano"
            },
            {
              "value": "pt",
              "label": "Português"
            },
            {
              "value": "nl",
              "label": "Nederlands"
            },
            {
              "value": "pl",
              "label": "Polski"
            },
            {
              "value": "ru",
              "label": "Русский"
            },
            {
              "value": "ja",
              "label": "日本語"
            },
            {
              "value": "zh",
              "label": "中文"
            },
            {
              "value": "ko",
              "label": "한국어"
            }
          ],
          "in_prompt": false
        }
      ]
    },
    {
      "id": "task_config",
      "label": "Task",
      "label_de": "Aufgabe",
      "column": 2,
      "row": 0,
      "fields": [
        {
          "key": "character_task",
          "label": "Tasks / Missions",
          "label_de": "Aufgaben / Missionen",
          "type": "text",
          "multiline": true,
          "source_file": "soul/tasks.md",
          "in_prompt": true,
          "prompt_label": "Your tasks/missions",
          "prompt_self_only": true,
          "llm_generable": true,
          "hint": "Describes what the character should do or what role they fulfill (in soul/tasks.md)",
          "hint_de": "Beschreibt was der Character tun soll oder welche Rolle er erfüllt (soul/tasks.md)",
          "editor_visible": false
        },
        {
          "key": "character_soul",
          "label": "Soul",
          "label_de": "Seele",
          "type": "text",
          "multiline": true,
          "source_file": "soul/soul.md",
          "in_prompt": true,
          "prompt_label": "Soul",
          "prompt_self_only": true,
          "prompt_requires_feature": "soul_enabled",
          "llm_generable": true,
          "hint": "Innermost identity: what moves you, what is sacred, deeper values (in soul/soul.md). Locked by default — sections can be opened with <!-- EDITABLE --> marker.",
          "hint_de": "Innerste Identität: was bewegt mich, was ist heilig, tiefere Werte (in soul/soul.md). Standardmäßig gesperrt — einzelne Sections per <!-- EDITABLE --> Marker freigeben.",
          "editor_visible": false
        }
      ]
    },
    {
      "id": "state",
      "label": "Current state",
      "label_de": "Aktueller Zustand",
