    {
      "id": "llm_config",
      "label": "Chat Mode",
      "label_de": "Chat-Modus",
      "column": 7,
      "row": 0,
      "fields": [
        {
          "key": "chat_mode",
          "label": "Chat mode",
          "label_de": "Chat-Modus",
          "type": "select",
          "options": [
            {
              "value": "",
              "label": "Single (Chat-LLM handles all)"
            },
            {
              "value": "rp_first",
              "label": "RP-First (Chat-LLM + Tool-LLM)"
            }
          ],
          "store": "config",
          "hint": "Single: Chat-LLM handles RP + tool decisions. RP-First: Chat-LLM writes clean RP, then Tool-LLM decides on tools. LLM-Wahl erfolgt zentral via LLM Routing.",
          "hint_de": "Single: Chat-LLM macht RP + Tool-Entscheidungen. RP-First: Chat-LLM schreibt sauberes RP, dann entscheidet Tool-LLM ueber Tools. LLM-Wahl erfolgt zentral ueber LLM Routing."
        }
      ]
    },
    {
      "id": "outfit_imagegen",
      "label": "Outfit Image Generator (Override)",
      "label_de": "Outfit-Bild Generator (Override)",
      "column": 20,
      "row": 0,
      "special": "outfit_imagegen",
      "fields": []
    },
    {
      "id": "appearance_config",
      "label": "Image Appearance",
      "label_de": "Bild-Darstellung",
      "column": 21,
      "column_span": 2,
      "row": 0,
      "special": "slot_overrides",
      "fields": []
    },
    {
      "id": "behavior_config",
      "label": "Behavior",
      "label_de": "Verhalten",
      "column": 8,
      "row": 0,
      "fields": [
        {
          "key": "relationships_enabled",
          "label": "Relationships",
          "label_de": "Beziehungen",
          "type": "select",
          "options": [
            {
              "value": "true",
              "label": "On",
              "label_de": "An"
            },
            {
              "value": "false",
              "label": "Off",
              "label_de": "Aus"
            }
          ],
          "store": "config",
          "default": "true",
          "hint": "Track relationships with other characters automatically",
          "hint_de": "Beziehungen zu anderen Charakteren automatisch verfolgen"
        },
        {
          "key": "mood_tracking",
          "label": "Mood tracking",
          "label_de": "Mood Tracking",
          "type": "select",
          "options": [
            {
              "value": "true",
              "label": "Yes",
              "label_de": "Ja"
            },
            {
              "value": "false",
              "label": "No",
              "label_de": "Nein"
            }
          ],
          "store": "config"
        },
        {
          "key": "photographer_mode",
          "label": "Photographer mode",
          "label_de": "Fotograf-Modus",
          "type": "select",
          "options": [
            {
              "value": "false",
              "label": "Off (appears in own photos)",
              "label_de": "Aus (erscheint in eigenen Fotos)"
            },
            {
              "value": "true",
              "label": "On (takes photos of others)",
              "label_de": "An (fotografiert andere)"
            }
          ],
          "store": "config",
          "default": "false",
          "hint": "When active, this character does NOT appear in photos they generate; only the subjects are shown. Ideal for paparazzi characters.",
          "hint_de": "Wenn aktiv, erscheint dieser Character NICHT in selbst generierten Fotos; nur die Motive sind zu sehen. Ideal fuer Paparazzi-Charaktere."
        },
        {
          "key": "avatar_only_presence",
          "label": "Avatar-only presence",
          "label_de": "Nur als Avatar präsent",
          "type": "select",
          "options": [
            {
              "value": "false",
              "label": "Off (always in world)",
              "label_de": "Aus (immer in der Welt)"
            },
            {
              "value": "true",
              "label": "On (vanishes when unattended)",
              "label_de": "An (verschwindet wenn ungesteuert)"
            }
          ],
          "store": "config",
          "default": "false",
          "hint": "When on, this character vanishes from the world while no one controls it, and reappears at its last controlled spot (or home location) when taken over as an avatar.",
          "hint_de": "Wenn an, verschwindet dieser Charakter aus der Welt solange ihn niemand steuert, und taucht beim Übernehmen am letzten Steuer-Ort (sonst Heimat-Ort) wieder auf."
        }
      ]
    },
    {
      "id": "telegram_config",
      "label": "Telegram",
      "label_de": "Telegram",
      "column": 9,
      "row": 0,
      "fields": [
        {
          "key": "telegram_bot_token",
          "label": "Bot Token",
          "label_de": "Bot Token",
          "type": "text",
          "store": "config",
          "hint": "Telegram Bot Token from @BotFather. Each character needs its own bot. After saving, use the Reload button to start polling.",
          "hint_de": "Telegram Bot-Token von @BotFather. Jeder Character braucht einen eigenen Bot. Nach dem Speichern den Reload-Button drücken."
        },
        {
          "key": "telegram_partner_character",
          "label": "Controlled Avatar",
          "label_de": "Gesteuerter Avatar",
          "type": "character_select",
          "store": "config",
          "hint": "The in-world character that the human on the other side of this Telegram bot is controlling. Used as partner identity for chat/relationship history. Leave empty to skip identity tagging.",
          "hint_de": "Welcher Charakter in der Welt vom Menschen auf der Telegram-Seite gesteuert wird. Wird als Partner-Identitaet fuer Chat/Beziehungs-Historie genutzt. Leer lassen um keinen Avatar zu setzen."
        }
      ]
    },
    {
      "id": "thoughts_config",
      "label": "Thoughts",
      "label_de": "Gedanken",
      "column": 9,
      "row": 1,
      "fields": [
        {
          "key": "thoughts_enabled",
          "label": "Enabled",
          "label_de": "Aktiviert",
          "type": "select",
          "options": [
            {
              "value": "false",
              "label": "No",
              "label_de": "Nein"
            },
            {
              "value": "true",
              "label": "Yes",
              "label_de": "Ja"
            }
          ],
          "store": "config",
          "hint": "If active, the character periodically thinks and can autonomously act (talk, send messages, change activity, etc.)",
          "hint_de": "Wenn aktiv, denkt der Character periodisch nach und kann autonom handeln (reden, Nachrichten senden, Aktivitaet aendern, etc.)"
        },
        {
          "key": "importance",
          "label": "Importance",
          "label_de": "Wichtigkeit",
          "type": "select",
          "options": [
            {
              "value": 1,
              "label": "Low",
              "label_de": "Niedrig"
            },
            {
              "value": 2,
              "label": "Medium",
              "label_de": "Mittel"
            },
            {
              "value": 3,
              "label": "High",
              "label_de": "Hoch"
            }
          ],
          "store": "config",
          "default": 1,
          "hint": "How often this character gets to think relative to others. High = 3x as often as Low.",
          "hint_de": "Wie oft dieser Character im Vergleich zu anderen denken darf. Hoch = 3x so oft wie Niedrig."
        },
        {
          "key": "retrospect_enabled",
          "label": "Retrospect",
          "label_de": "Retrospektive",
          "type": "select",
          "options": [
            {
              "value": "false",
              "label": "No",
              "label_de": "Nein"
            },
            {
              "value": "true",
              "label": "Yes",
              "label_de": "Ja"
            }
          ],
          "store": "config",
          "default": "true",
          "hint": "If active, the character periodically reflects on recent events to update their beliefs, lessons learned, and goals. Disabling hides those sections from the editor.",
          "hint_de": "Wenn aktiv, reflektiert der Character regelmaessig ueber die juengsten Ereignisse und aktualisiert seine Ueberzeugungen, Lektionen und Ziele. Deaktivieren blendet diese Abschnitte im Editor aus."
        }
      ]
    },
    {
      "id": "tts_config",
      "label": "Speech (TTS)",
      "label_de": "Sprache (TTS)",
