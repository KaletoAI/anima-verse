      "row": 1,
      "fields": [
        {
          "key": "current_location",
          "label": "Current location",
          "label_de": "Aktueller Ort",
          "type": "text",
          "readonly": true,
          "workflow_required": [
            "image_generation"
          ],
          "hint": "Set via header",
          "hint_de": "Wird über den Header gesetzt",
          "in_prompt": false
        },
        {
          "key": "current_activity",
          "label": "Current activity",
          "label_de": "Aktuelle Aktivität",
          "type": "text",
          "readonly": true,
          "workflow_required": [
            "image_generation"
          ],
          "hint": "Set via header",
          "hint_de": "Wird über den Header gesetzt",
          "in_prompt": false
        },
        {
          "key": "current_room",
          "label": "Current room",
          "label_de": "Aktueller Raum",
          "type": "text",
          "readonly": true,
          "hint": "Automatically set based on activity",
          "hint_de": "Wird automatisch basierend auf Aktivität gesetzt",
          "in_prompt": false
        },
        {
          "key": "current_feeling",
          "label": "Current mood",
          "label_de": "Aktuelle Stimmung",
          "type": "text",
          "readonly": true,
          "workflow_required": [
            "image_generation",
            "chat"
          ],
          "hint": "Set via chat (SetMood)",
          "hint_de": "Wird über den Chat gesetzt (SetMood)",
          "in_prompt": true,
          "prompt_label": "Current feeling",
          "prompt_requires_feature": "mood_tracking_enabled",
          "prompt_self_only": true
        }
      ]
    },
