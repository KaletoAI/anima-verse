          "label": "Category",
          "label_de": "Kategorie"
        },
        "severity": {
          "label": "Severity (1-5)",
          "label_de": "Schwere (1-5)"
        },
        "related_chars": {
          "label": "Related characters (comma-sep.)",
          "label_de": "Beteiligte Charaktere (kommagetrennt)"
        },
