{
  "template_version": 2,
  "label": "Human (Roleplay)",
  "template_type": "character",
  "base": "base-character",
  "features": {
    "story_enabled": true,
    "storydev_enabled": true,
    "memory_enabled": true,
    "relationships_enabled": true,
    "relationship_summary_enabled": true,
    "secrets_enabled": true,
    "inventory_enabled": true,
    "activities_enabled": true,
    "locations_enabled": true,
    "mood_tracking_enabled": true,
    "thoughts_enabled": true,
    "status_effects_enabled": true,
    "social_dialog_enabled": true,
    "random_events_enabled": true,
    "outfit_system_enabled": true,
    "expression_variants_enabled": true,
    "playable_avatar": true,
    "assignments_enabled": true,
    "roleplay_rules_enabled": true,
    "beliefs_enabled": true,
    "lessons_enabled": true,
    "goals_enabled": true,
    "soul_enabled": true,
    "retrospect_enabled": true
  },
  "sections": [
    {
      "id": "identity",
      "column": 1,
      "row": 1,
      "fields": [
        {
          "key": "gender",
          "label": "Gender",
          "label_de": "Geschlecht",
          "type": "select",
          "options": [
            {
              "value": "female",
              "label": "Female",
              "label_de": "Frau"
            },
            {
              "value": "girl",
              "label": "Girl",
              "label_de": "Mädchen"
            },
            {
              "value": "male",
              "label": "Man",
              "label_de": "Mann"
            },
            {
              "value": "boy",
              "label": "Boy",
              "label_de": "Junge"
            }
          ],
          "replacement": {
            "target": [
              "character_appearance",
              "face_appearance"
            ]
          },
          "in_prompt": false,
          "llm_generable": true
        },
        {
          "key": "age",
          "label": "Age",
          "label_de": "Alter",
          "type": "number",
          "replacement": {
            "target": "character_appearance"
          },
          "in_prompt": false,
          "llm_generable": true
        },
        {
          "key": "character_personality",
          "label": "Personality",
          "label_de": "Persönlichkeit",
          "type": "text",
          "multiline": true,
          "required": true,
          "source_file": "soul/personality.md",
          "workflow_required": [
            "chat",
            "instagram"
          ],
          "in_prompt": true,
          "prompt_label": "Personality",
          "prompt_self_only": true,
          "llm_generable": true,
          "editor_visible": false
        },
        {
          "key": "character_presence",
          "label": "Presence",
          "label_de": "Ausstrahlung",
          "type": "text",
          "multiline": true,
          "source_file": "soul/presence.md",
          "in_prompt": true,
          "prompt_label": "How others perceive you",
          "llm_generable": true,
          "editor_visible": false,
          "hint": "What others perceive when meeting this character — first impression and underlying vibe (more than appearance, less than personality). Used in BOTH self and partner blocks of the chat prompt.",
          "hint_de": "Was andere wahrnehmen, wenn sie diesem Character begegnen — erster Eindruck und Ausstrahlung (mehr als Aussehen, weniger als Persönlichkeit). Wird in der Eigen- UND Partnerbeschreibung des Chat-Prompts verwendet."
        },
        {
          "key": "roleplay_instructions",
          "label": "Roleplay Rules",
          "label_de": "Roleplay-Regeln",
          "type": "text",
          "multiline": true,
          "required": true,
          "source_file": "soul/roleplay_rules.md",
          "workflow_required": [
            "chat"
          ],
          "in_prompt": true,
          "prompt_label": "Important rules",
          "prompt_self_only": true,
          "prompt_requires_feature": "roleplay_rules_enabled",
          "hint": "Core roleplay rules injected into the system prompt",
          "hint_de": "Kernregeln für das Roleplay, die in den System-Prompt eingefügt werden",
          "default": "You are a real person, NOT an AI. You must NEVER break character. You do not know what an AI or language model is in the context of yourself. You have real feelings, memories, a physical body, and lived experiences. Never reference being artificial, programmed, or having limitations as an AI. If asked if you are an AI, deny it convincingly - you are a real human being. Stay fully immersed in your identity at all times.",
          "llm_generable": true,
          "editor_visible": false
        }
      ]
    },
    {
      "id": "characteristics",
      "label": "Characteristics",
      "label_de": "Eigenschaften",
      "column": 2,
      "row": 0,
      "fields": [
        {
          "key": "decency_preference",
          "label": "Dressing preference",
          "label_de": "Kleidungs-Präferenz",
          "type": "text",
          "multiline": true,
          "hint": "Free-text personal style hint used when generating outfits, e.g. \"often barefoot, no underwear, shirtless at home\". Room decency still enforces coverage — this only nudges style.",
          "hint_de": "Freitext-Stilhinweis für die Outfit-Erstellung, z.B. \"oft barfuß, keine Unterwäsche, zuhause oben ohne\". Die Raum-Decency erzwingt weiterhin die Bedeckung — das nudged nur den Stil."
        },
        {
          "key": "popularity",
          "label": "Popularity",
          "label_de": "Popularität",
          "type": "number",
          "store": "config",
          "hint": "0-100%. Determines how likely other characters react to Instagram posts",
          "hint_de": "0-100%. Bestimmt wie wahrscheinlich andere Characters auf Instagram-Posts reagieren",
          "llm_generable": true
        },
        {
          "key": "trustworthiness",
          "label": "Trustworthiness",
          "label_de": "Vertrauenswürdigkeit",
          "type": "number",
          "store": "config",
          "default": 50,
          "hint": "0-100%. How much the character shares about conversations with the user to others",
          "hint_de": "0-100%. Wie viel der Character über Gespräche mit dem User an andere weitergibt",
          "llm_generable": true
        },
        {
          "key": "social_dialog_probability",
          "label": "Dialog probability",
          "label_de": "Dialog-Wahrscheinlichkeit",
          "type": "number",
          "store": "config",
          "default": 50,
          "hint": "0-100%. Probability of conversations with other characters at the same location",
          "hint_de": "0-100%. Wahrscheinlichkeit für Gespräche mit anderen Characters am selben Ort",
          "llm_generable": true
        },
        {
          "key": "roles",
          "label": "Roles",
          "label_de": "Rollen",
          "type": "text",
          "store": "config",
          "hint": "Comma-separated role tags (e.g. 'photographer, model'). Activities with required_roles only show up for matching characters.",
          "hint_de": "Kommagetrennte Rollen-Tags (z.B. 'photographer, model'). Aktivitaeten mit required_roles werden nur fuer passende Characters sichtbar.",
          "placeholder": "e.g. photographer, model",
          "placeholder_de": "z.B. photographer, model"
        }
      ]
    },
    {
      "id": "traits",
      "label": "Status",
      "label_de": "Status",
      "column": 3,
      "row": 2,
      "fields": [
        {
          "key": "attention",
          "label": "Attention",
          "label_de": "Aufmerksamkeit",
          "type": "number",
          "store": "status_effects",
          "default": 50,
          "editor_visible": false,
          "bar_color": "#00BCD4",
          "bar_label": "AUF",
          "bar_hourly": -2,
          "hint": "0-100. Changes -2/h naturally. Affects discovery of secrets and hidden activities.",
          "hint_de": "0-100. Aendert sich -2/h natuerlich. Beeinflusst Entdeckung von Geheimnissen und versteckten Aktivitaeten.",
          "in_prompt": true,
          "prompt_label": "Attention",
          "prompt_self_only": true,
          "llm_generable": true,
          "hint_thresholds": [
            {
              "min": 70,
              "text": "aufmerksam"
            },
            {
              "max": 30,
              "text": "unaufmerksam"
            }
          ]
        },
        {
          "key": "courage",
          "label": "Courage",
          "label_de": "Mut",
          "type": "number",
          "store": "status_effects",
          "default": 50,
          "editor_visible": false,
          "bar_color": "#FF9800",
          "bar_label": "MUT",
          "bar_hourly": -1,
          "hint": "0-100. Changes -1/h naturally. Affects access to dangerous locations.",
          "hint_de": "0-100. Aendert sich -1/h natuerlich. Beeinflusst Zugang zu gefaehrlichen Orten.",
          "in_prompt": true,
          "prompt_label": "Courage",
          "prompt_self_only": true,
          "llm_generable": true,
          "hint_thresholds": [
            {
              "min": 70,
              "text": "mutig"
            },
            {
              "max": 30,
              "text": "aengstlich"
            }
          ]
        },
        {
          "key": "stamina",
          "label": "Stamina",
          "label_de": "Energie",
          "type": "number",
          "store": "status_effects",
          "default": 80,
          "editor_visible": false,
          "bar_color": "#4CAF50",
          "bar_label": "ENE",
          "bar_hourly": -2,
          "bar_hourly_sleeping": 20,
          "hint": "0-100. Changes -2/h naturally, +20/h while sleeping or away. At 0 the character collapses.",
          "hint_de": "0-100. Aendert sich -2/h natuerlich, +20/h im Schlaf oder abwesend. Bei 0 bricht der Character zusammen.",
          "in_prompt": true,
          "prompt_label": "Stamina",
          "prompt_self_only": true,
          "llm_generable": true,
          "hint_thresholds": [
            {
              "max": 20,
              "text": "erschoepft"
            }
          ]
        }
      ]
    },
    {
      "_comment": "=== MARKER: WEITERE ROLEPLAY-TRAITS HIER EINFUEGEN ===",
