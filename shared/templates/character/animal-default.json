        },
        {
          "key": "character_presence",
          "label": "Presence",
          "label_de": "Ausstrahlung",
          "type": "text",
          "multiline": true,
          "source_file": "soul/presence.md",
          "in_prompt": true,
          "prompt_label": "How others perceive you",
          "llm_generable": true,
          "editor_visible": false,
          "hint": "What others perceive when meeting this animal — first impression and underlying vibe (more than appearance, less than personality). Used in BOTH self and partner blocks of the chat prompt.",
          "hint_de": "Was andere wahrnehmen, wenn sie diesem Tier begegnen — erster Eindruck und Ausstrahlung (mehr als Aussehen, weniger als Persönlichkeit). Wird in der Eigen- UND Partnerbeschreibung des Chat-Prompts verwendet."
        }
      ]
    },
    {
      "id": "characteristics",
      "label": "Characteristics",
      "label_de": "Eigenschaften",
      "column": 2,
      "row": 0,
      "fields": [
        {
          "key": "communication",
          "label": "Communication style",
          "label_de": "Kommunikationsstil",
          "type": "text",
          "multiline": true,
          "in_prompt": true,
          "prompt_label": "Communication",
          "hint": "How the animal communicates (sounds, body language, thoughts in italics, etc.)",
          "hint_de": "Wie das Tier kommuniziert (Geräusche, Körpersprache, Gedanken in Kursiv, etc.)",
          "llm_generable": true
        },
        {
          "key": "romantic_interests",
          "label": "Romantic Interests",
          "label_de": "Romantische Interessen",
          "type": "text",
          "store": "config",
          "hint": "Describe romantic/sexual interests (e.g. \"women\", \"tall dark men\", \"dominant personalities\"). Empty = none.",
          "hint_de": "Romantische/sexuelle Interessen beschreiben (z.B. \"Frauen\", \"grosse dunkle Maenner\", \"dominante Persoenlichkeiten\"). Leer = keine.",
          "placeholder": "e.g. women, dominant men...",
          "placeholder_de": "z.B. Frauen, dominante Maenner..."
        }
      ]
    },
    {
      "id": "appearance",
      "label": "Appearance",
      "label_de": "Aussehen",
      "column": 5,
      "row": 0,
      "fields": [
        {
          "key": "character_appearance",
          "help": "image_prompt",
          "label": "Appearance",
          "label_de": "Aussehen",
          "type": "text",
          "multiline": true,
          "required": true,
          "image_preview": "appearance",
          "workflow_required": [
            "image_generation"
          ],
          "in_prompt": true,
          "prompt_label": "Appearance",
          "default": "{animal_size} {species}, {breed}, {fur_type}, {primary_color} {pattern}, {eye_color}",
          "llm_generable": true,
          "rows": 2
        }
      ]
