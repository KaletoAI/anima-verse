{
  "rules": [
    {
      "name": "Exhaustion",
      "name_de": "Erschöpfung",
      "type": "force",
      "condition": "stamina<10",
      "message": "Worn out, going to sleep.",
      "message_de": "Bin erschöpft, gehe schlafen.",
      "force_action": {
        "go_to": "home",
        "set_activity": "sleeping",
        "set_flags": { "is_sleeping": true }
      },
      "id": "default_sleep_when_exhausted"
    },
    {
      "name": "Waking up",
      "name_de": "Aufwachen",
      "type": "force",
      "condition": "stamina>70 AND is_sleeping AND NOT schedule:sleeping",
      "message": "Well-rested, waking up.",
      "message_de": "Ausgeschlafen, wache auf.",
      "force_action": {
        "go_to": "stay",
        "set_activity": "",
        "set_flags": { "is_sleeping": false }
      },
      "id": "default_wake_when_rested"
    },
    {
      "name": "Fully rested",
      "name_de": "Ausgeschlafen",
      "type": "force",
      "condition": "stamina>99 AND is_sleeping",
      "message": "You wake up, fully rested.",
      "message_de": "Du wachst auf, da Du ausgeschlafen bist.",
      "force_action": {
        "go_to": "stay",
        "set_activity": "",
        "set_flags": { "is_sleeping": false }
      },
      "id": "rule_f4e31679"
    },
    {
      "name": "Awareness",
      "name_de": "Wahrnehmung",
      "type": "discover",
      "condition": "attention>80",
      "message": "Out of the corner of your eye you notice a place you didn't know yet.",
      "message_de": "Aus dem Augenwinkel fällt dir ein Ort auf, den du noch nicht kanntest.",
      "probability": 0.3,
      "id": "rule_04d219e2"
    }
  ]
}
